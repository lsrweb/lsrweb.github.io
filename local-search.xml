3D; document.querySelector(&#39;.left&#39;);<br>      let oRight &#x3D; document.querySelector(&#39;.right&#39;);<br>      let oImgList &#x3D; document.querySelector(&#39;.imgList&#39;);<br>      let outBox &#x3D; document.querySelector(&#39;.wrap&#39;);<br>      let maxImgLength &#x3D; document.querySelectorAll(&#39;.imgList img&#39;).length;<br>      let imgWidth &#x3D; document.querySelectorAll(&#39;.imgList img&#39;)[0].clientWidth;<br><br>      oImgList.appendChild(oImgList.firstElementChild.cloneNode());<br>      &#x2F;&#x2F; 定时器<br>      function timeBan() &#123;<br>         timer &#x3D; setInterval(rightBan, 3000);<br>      &#125;<br>      timeBan();<br>      &#x2F;&#x2F; 封装右侧 轮播函数<br>      function rightBan() &#123;<br>         if (!lock) return;<br>         index++;<br>         if (index &#x3D;&#x3D;&#x3D; maxImgLength) &#123;<br>            setTimeout(function () &#123;<br>               oImgList.style.transition &#x3D; &#39;none&#39;;<br>               oImgList.style.left &#x3D; 0;<br>               index &#x3D; 0;<br>            &#125;, 500);<br>         &#125;<br>         oImgList.style.transition &#x3D; &#39;0.5s ease&#39;;<br>         oImgList.style.left &#x3D; -index * imgWidthScreenGet + &#39;px&#39;;<br>         spanIndex++;<br>         if (index &#x3D;&#x3D;&#x3D; 5) &#123;<br>            spanIndex &#x3D; 0;<br>         &#125;<br>         $(&#39;.circleActive&#39;).eq(spanIndex).addClass(&#39;active&#39;).siblings().removeClass(&#39;active&#39;);<br>         &#x2F;&#x2F; 关阀<br>         lock &#x3D; false;<br>         setTimeout(function () &#123;<br>            lock &#x3D; true;<br>         &#125;, 500);<br>      &#125;<br>      &#x2F;&#x2F; 右侧按钮<br>      oRight.onclick &#x3D; function () &#123;<br>         rightBan();<br>      &#125;;<br>      &#x2F;&#x2F;左侧按钮<br>      oleft.onclick &#x3D; function () &#123;<br>         if (!lock) return;<br>         if (index &#x3D;&#x3D;&#x3D; 0) &#123;<br>            oImgList.style.left &#x3D; -maxImgLength * 800 + &#39;px&#39;;<br>            oImgList.style.transition &#x3D; &#39;none&#39;;<br>            &#x2F;&#x2F; 设置延时器的目的 可以让过渡瞬间取消 然后再次加上<br>            setTimeout(function () &#123;<br>               oImgList.style.transition &#x3D; &#39;0.5s ease&#39;;<br>               index &#x3D; maxImgLength - 1;<br>               oImgList.style.left &#x3D; (-maxImgLength - -1) * 800 + &#39;px&#39;;<br>            &#125;, 0);<br>         &#125; else &#123;<br>            index--;<br>            oImgList.style.left &#x3D; -index * 800 + &#39;px&#39;;<br>         &#125;<br>         lock &#x3D; false;<br>         setTimeout(function () &#123;<br>            lock &#x3D; true;<br>         &#125;, 500);<br>      &#125;;<br>      &#x2F;&#x2F; 左右按钮经过停止<br>      outBox.onmouseover &#x3D; function () &#123;<br>         clearInterval(timer);<br>         timer &#x3D; null;<br>      &#125;;<br>      outBox.onmouseout &#x3D; function () &#123;<br>         timeBan();<br>      &#125;;<br>      &#x2F;&#x2F; 追加圆点<br>      for (let i &#x3D; 0; i &lt; maxImgLength; i++) &#123;<br>         let circleFather &#x3D; document.querySelector(&#39;.circle&#39;); &#x2F;&#x2F;获取父级元素<br>         let circleChil &#x3D; document.createElement(&#39;span&#39;); &#x2F;&#x2F;创建元素节点<br>         circleChil.setAttribute(&#39;class&#39;, &#39;circleActive&#39;); &#x2F;&#x2F;设置追加元素的classi<br>         circleFather.appendChild(circleChil)[i]; &#x2F;&#x2F;依据图片数量追加span元素<br>      &#125;<br>      $(&#39;.circleActive&#39;).eq(0).addClass(&#39;active&#39;);<br>      $(&#39;.circleActive&#39;).hover(function () &#123;<br>         index &#x3D; $(this).index();<br>         oImgList.style.transition &#x3D; &#39;0.5s ease&#39;;<br>         oImgList.style.left &#x3D; -index * 800 + &#39;px&#39;;<br>         $(&#39;.circleActive&#39;).eq(index).addClass(&#39;active&#39;).siblings().removeClass(&#39;active&#39;);<br>      &#125;);<br><br>      &#x2F;&#x2F; 时刻监听浏览器可是窗口大小并将大小赋值给图片, bug:需要刷新,等待解决<br><br>      window.onresize &#x3D; function () &#123;<br>         if (document.body.clientWidth &lt;&#x3D; imgWidth) &#123;<br>            $(&#39;.imgList img&#39;).attr(&#123;<br>               width: document.body.clientWidth,<br>            &#125;);<br>            &#x2F;&#x2F; 刷新点<br>            location.reload();<br>            let screenWidth &#x3D; document.body.clientWidth;<br>            oImgList.style.left &#x3D; -screenWidth + &#39;px&#39;;<br>         &#125;<br>      &#125;;<br>      window.onload &#x3D; function () &#123;<br>         var point &#x3D; document.body.clientWidth;<br><br>         function toPercent(point) &#123;<br>            var percent &#x3D; Number(point &#x2F; 100);<br>            return percent;<br>         &#125;<br>         var result &#x3D; toPercent(point);<br>         $(&#39;.imgList img&#39;).attr(&#123;<br>            width: result * 100,<br>         &#125;);<br>         if (document.body.clientWidth &lt;&#x3D; imgWidth) &#123;<br>            $(&#39;.imgList img&#39;).attr(&#123;<br>               width: document.body.clientWidth,<br>            &#125;);<br>            let screenWidth &#x3D; document.body.clientWidth;<br>            imgWidthScreenGet &#x3D; document.body.clientWidth;<br>            console.log(imgWidthScreenGet);<br>         &#125; else &#123;<br>            imgWidthScreenGet &#x3D; imgWidth;<br>         &#125;<br>      &#125;;<br><br>   &lt;&#x2F;script&gt;<br>&lt;&#x2F;body&gt;<br><br>&lt;&#x2F;html&gt;<br></code></pre></td></tr></table></figure><p>上述代码存在Bug,但左右切换均正常</p><h3>实现原理</h3><p>其实左右无缝轮播的实现原理十分简单</p><p>首先需要一个装所有图片的盒子。然后通过移动装图片的盒子来使图片显示出来。(也就是更改left值,并加入transform过渡)</p><p>如果需要感觉图片移动时连贯的话，就需要将第一张图片复制一张到最后面，然后当图片切换到最后一张图片时候，立马将图片跳转至第一张，就会给我们一种图片是连贯的错觉。</p>需要用到的知识点：定位，浮动，动画，定时器<h1>利用插件实现左右无缝轮播效果</h1><a href="https://www.swiper.com.cn/demo/index.html">第一个插件: Swiper</a><br /><a href="http://www.superslide2.com/demo.html">第二个插件: SuperSlide</a><p>利用插件实现效果就很简单了,这里就不做过多演示啦</p><script src="https://cdn.jsdelivr.net/npm/aplayer/dist/APlayer.min.js"></script><script src="https://cdn.jsdelivr.net/npm/meting@2/dist/Meting.min.js"></script><p><meting-js autoplay="false" fixed="true" lrc-type="1"auto="https://y.qq.com/n/yqq/playlist/7698025666.html"></meting-js></p>]]></content>
    
    
